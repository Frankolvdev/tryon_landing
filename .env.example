# URL pública del backend FastAPI. No agregues una barra al final.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001

# Tiempo máximo de espera para solicitudes públicas del frontend.
NEXT_PUBLIC_API_TIMEOUT_MS=10000

# URL pública canónica de la landing, utilizada por metadata, sitemap y robots.
# En producción debe ser HTTPS y no llevar barra final.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
